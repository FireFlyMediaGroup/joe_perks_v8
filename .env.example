# Aggregate reference — copy values into root `.env` and per-app `.env.local` (see docs/AGENTS.md).

# Shared / root
# DATABASE_URL=
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# RESEND_TOKEN=          # re_... (see @joe-perks/email/keys.ts)
# RESEND_FROM=           # optional
# INNGEST_SIGNING_KEY=
# INNGEST_EVENT_KEY=
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# SENTRY_AUTH_TOKEN=

# apps/web (.env.local)
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=
# UPLOADTHING_SECRET=
# UPLOADTHING_APP_ID=

# apps/roaster (.env.local)
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
# CLERK_SECRET_KEY=

# apps/org (.env.local)
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
# CLERK_SECRET_KEY=

# apps/admin (.env.local)
# ADMIN_EMAIL=
# ADMIN_PASSWORD=
