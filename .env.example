# Aggregate reference — copy values into root `.env` and per-app `.env.local` (see docs/AGENTS.md).
#
# IMPORTANT: Do NOT set empty-string overrides in per-app `.env.local` for variables
# that have values in root `.env` (e.g. STRIPE_SECRET_KEY=""). The empty string will
# mask the real value. Only add a variable to `.env.local` to override with a non-empty value.
# See docs/AGENTS.md → "Empty-string overrides" for details.

# Shared / root
# DATABASE_URL=
#
# --- Stripe (test mode first) ---
# 1) Dashboard → Settings → Connect → Get started (Express) — complete platform profile if prompted.
# 2) Dashboard → Developers → API keys — copy Secret key → STRIPE_SECRET_KEY (sk_test_...)
# 3) Webhooks: add endpoint URL for apps/web, e.g. https://YOUR_DOMAIN/api/webhooks/stripe
#    Subscribe: account.updated (and later: payment_intent.*, charge.dispute.*, transfer.failed per checklist).
#    Reveal signing secret → STRIPE_WEBHOOK_SECRET (whsec_...).
#    Local dev: `stripe listen --forward-to localhost:3000/api/webhooks/stripe` — use the CLI whsec as STRIPE_WEBHOOK_SECRET.
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# RESEND_TOKEN=          # re_... (see @joe-perks/email/keys.ts)
# RESEND_FROM=           # optional
# INNGEST_SIGNING_KEY=
# INNGEST_EVENT_KEY=
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# SENTRY_AUTH_TOKEN=

# apps/web (.env.local)
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=   # pk_test_... — same mode (test/live) as STRIPE_SECRET_KEY
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=
# UPLOADTHING_SECRET=
# UPLOADTHING_APP_ID=

# apps/roaster (.env.local)
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
# CLERK_SECRET_KEY=
# ROASTER_APP_ORIGIN=          # optional — public base URL for Stripe Connect return/refresh (default http://localhost:3001)

# apps/org (.env.local)
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
# CLERK_SECRET_KEY=

# apps/admin (.env.local)
# ADMIN_EMAIL=
# ADMIN_PASSWORD=
