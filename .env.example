# Aggregate reference — copy values into root `.env` and per-app `.env.local` (see docs/AGENTS.md).

# Shared / root
# DATABASE_URL=
# STRIPE_SECRET_KEY=          # sk_test_... (dev) — from Stripe Dashboard → Developers → API keys
# STRIPE_WEBHOOK_SECRET=      # whsec_... — from Developers → Webhooks → endpoint signing secret
#
# Stripe Connect (Express): enable in Dashboard → Settings → Connect before onboarding.
# Webhook URL (production): https://joeperks.com/api/webhooks/stripe — subscribe at least: account.updated
# RESEND_TOKEN=          # re_... (see @joe-perks/email/keys.ts)
# RESEND_FROM=           # optional
# INNGEST_SIGNING_KEY=
# INNGEST_EVENT_KEY=
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# SENTRY_AUTH_TOKEN=

# apps/web (.env.local)
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=   # pk_test_... — same mode (test/live) as STRIPE_SECRET_KEY
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=
# UPLOADTHING_SECRET=
# UPLOADTHING_APP_ID=

# apps/roaster (.env.local)
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
# CLERK_SECRET_KEY=
# ROASTER_APP_ORIGIN=          # optional — public base URL for Stripe Connect return/refresh (default http://localhost:3001)

# apps/org (.env.local)
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
# CLERK_SECRET_KEY=

# apps/admin (.env.local)
# ADMIN_EMAIL=
# ADMIN_PASSWORD=
