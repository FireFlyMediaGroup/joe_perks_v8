{
  "name": "next-forge",
  "version": "6.0.2",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/FireFlyMediaGroup/joe_perks_v8.git"
  },
  "publishConfig": {
    "provenance": true,
    "access": "public"
  },
  "bin": {
    "next-forge": "dist/index.js"
  },
  "files": [
    "dist/index.js"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev --filter='!@repo/cms' --filter='!studio'",
    "dev:all": "turbo dev",
    "dev:studio": "pnpm --filter studio dev",
    "check": "ultracite check",
    "typecheck": "turbo typecheck",
    "fix": "ultracite fix",
    "test": "turbo test",
    "test:e2e:frontend": "playwright test tests/e2e/frontend",
    "test:e2e:frontend:headed": "playwright test tests/e2e/frontend --headed",
    "analyze": "turbo analyze",
    "translate": "turbo translate",
    "boundaries": "turbo boundaries",
    "bump-deps": "bunx npm-check-updates --deep -u && bun install",
    "bump-ui": "bunx shadcn@latest add --all --overwrite -c packages/design-system",
    "migrate": "cd packages/db && bunx prisma format && bunx prisma generate && bunx prisma migrate dev",
    "migrate:deploy": "cd packages/db && bunx prisma generate && bunx prisma migrate deploy",
    "migrate:deploy:prod": "cd packages/db && PRISMA_DATABASE_PROFILE=production bunx prisma generate && PRISMA_DATABASE_PROFILE=production bunx prisma migrate deploy",
    "db:smoke": "cd packages/db && bun run ./scripts/smoke-db.ts",
    "db:smoke:us-03-02": "cd packages/db && bun run ./scripts/smoke-us-03-02-admin-org-queue.ts",
    "db:smoke:sprint-3": "cd packages/db && bun run ./scripts/smoke-sprint-3.ts",
    "db:smoke:us-04-01": "cd packages/db && bun run ./scripts/smoke-us-04-01-storefront.ts",
    "db:smoke:us-06-01": "cd packages/db && bun run ./scripts/smoke-us-06-01-payout.ts",
    "admin:smoke:us-07": "bun run ./apps/admin/scripts/smoke-us-07.ts",
    "smoke:prod": "node ./scripts/smoke-production-http.mjs",
    "e2e:sprint3": "cd packages/db && bun run ./scripts/e2e-sprint-3.ts",
    "e2e:stripe-listen": "node ./scripts/stripe-listen-from-root-env.mjs",
    "e2e:stripe-trigger": "node ./scripts/stripe-trigger-from-root-env.mjs",
    "db:smoke:prod": "cd packages/db && PRISMA_DATABASE_PROFILE=production bun run ./scripts/smoke-db.ts",
    "db:seed:prod": "cd packages/db && PRISMA_DATABASE_PROFILE=production bunx prisma db seed",
    "db:seed:e2e:frontend": "cd packages/db && bun run ./seed.ts && bun run ./scripts/seed-e2e-roaster.ts && bun run ./scripts/seed-e2e-org.ts && bun run ./scripts/seed-e2e-orders.ts && bun run ./scripts/write-playwright-fixtures.ts",
    "db:seed:e2e:prod": "node ./scripts/run-prod-e2e-seed.mjs",
    "db:push": "cd packages/db && bunx prisma format && bunx prisma generate && bunx prisma db push",
    "vercel:env:sync": "node ./scripts/vercel-sync-envs.mjs",
    "clean": "git clean -xdf node_modules",
    "release": "npm publish"
  },
  "devDependencies": {
    "@auto-it/first-time-contributor": "^11.3.6",
    "@biomejs/biome": "2.4.6",
    "@playwright/test": "^1.59.1",
    "@repo/typescript-config": "workspace:*",
    "@turbo/gen": "^2.8.14",
    "@types/node": "^25.3.5",
    "tsup": "^8.5.1",
    "turbo": "^2.8.14",
    "typescript": "^5.9.3",
    "ultracite": "7.2.5",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.31.0",
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "commander": "^14.0.3",
    "nypm": "^0.6.5"
  },
  "overrides": {
    "parse5": "^7.2.1",
    "next": "16.2.1"
  },
  "type": "module"
}
