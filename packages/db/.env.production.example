# Neon **main** (production) branch — pooled connection string from the Neon dashboard.
# Copy to `.env.production` in this folder (gitignored) and never commit secrets.
#
# Usage:
#   pnpm migrate:deploy:prod   # apply migrations
#   pnpm db:seed:prod          # seed singleton rows (PlatformSettings, OrderSequence)
#   pnpm db:smoke:prod         # verify schema + singletons + recent migrations
#
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"
