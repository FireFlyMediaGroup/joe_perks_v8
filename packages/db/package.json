{
  "name": "@joe-perks/db",
  "version": "0.0.0",
  "main": "./index.ts",
  "types": "./index.ts",
  "exports": {
    ".": "./index.ts",
    "./admin-action-log": "./admin-action-log.ts",
    "./keys": "./keys.ts",
    "./database": "./database.ts",
    "./clerk-user-sync": "./clerk-user-sync.ts",
    "./generated/client": "./generated/client.ts"
  },
  "scripts": {
    "analyze": "prisma generate --no-hints --schema=./prisma/schema.prisma",
    "build": "prisma generate --no-hints --schema=./prisma/schema.prisma",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false",
    "db:smoke": "bun run ./scripts/smoke-db.ts",
    "db:smoke:us-03-02": "bun run ./scripts/smoke-us-03-02-admin-org-queue.ts",
    "db:smoke:sprint-3": "bun run ./scripts/smoke-sprint-3.ts",
    "seed:e2e": "bun run ./scripts/seed-e2e-roaster.ts && bun run ./scripts/seed-e2e-org.ts"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.2",
    "@prisma/adapter-neon": "7.4.2",
    "@prisma/client": "7.4.2",
    "@prisma/client-runtime-utils": "^7.4.2",
    "@t3-oss/env-nextjs": "^0.13.10",
    "server-only": "^0.0.1",
    "undici": "^7.22.0",
    "ws": "^8.19.0",
    "zod": "^4.3.6"
  },
  "prisma": {
    "seed": "bun run ./seed.ts"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/node": "25.3.5",
    "@types/ws": "^8.18.1",
    "bufferutil": "^4.1.0",
    "dotenv": "^16.5.0",
    "prisma": "7.4.2",
    "typescript": "^5.9.3"
  }
}
