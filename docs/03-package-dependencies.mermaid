---
title: Joe Perks — Package Dependency Graph
---
graph TD
  %% ── Apps (consumers) ────────────────────────────────────────────
  subgraph APPS["apps — Next.js 14 App Router"]
    WEB["apps/web"]:::app
    ROASTER["apps/roaster"]:::app
    ORG["apps/org"]:::app
    ADMIN["apps/admin"]:::app
  end

  %% ── Shared packages ─────────────────────────────────────────────
  subgraph PKGS["packages — shared internal libraries"]
    DB["@joe-perks/db\n─────────────────\nPrisma 5.x client\n26 models, all enums\ncalculateSplits() host\norder number generation\nEmailLog dedup queries"]:::pkg

    UI["@joe-perks/ui\n─────────────────\nshadcn/ui components\nbrand theme CSS vars\nuseCart() Zustand store\nLocalStorage cart persist"]:::pkg

    STRIPE_PKG["@joe-perks/stripe\n─────────────────\nStripe Node.js client\ncalculateSplits()\nUpstash ratelimit helpers\nwebhook verify helper"]:::pkg

    EMAIL_PKG["@joe-perks/email\n─────────────────\nResend client\nsendEmail() + EmailLog\n11 React Email templates\ntracking URL map"]:::pkg

    TYPES["@joe-perks/types\n─────────────────\nShared TypeScript types\nRESERVED_SLUGS constant\nOrderSplits interface\nFulfillmentStatus enums"]:::pkg
  end

  %% ── External services (owned by packages) ───────────────────────
  subgraph EXT["external — third-party APIs"]
    NEON[("Neon Postgres\nDATABASE_URL\nShared single DB\nDev + prod branches")]:::ext
    STRIPE_API[("Stripe Connect\nSTRIPE_SECRET_KEY\nSTRIPE_WEBHOOK_SECRET")]:::ext
    RESEND_API[("Resend\nRESEND_API_KEY")]:::ext
    UPSTASH_API[("Upstash Redis\nUPSTASH_REDIS_REST_URL\nUPSTASH_REDIS_REST_TOKEN")]:::ext
  end

  %% ── App → package dependencies ───────────────────────────────────
  WEB     --> DB
  WEB     --> UI
  WEB     --> STRIPE_PKG
  WEB     --> EMAIL_PKG
  WEB     --> TYPES

  ROASTER --> DB
  ROASTER --> UI
  ROASTER --> EMAIL_PKG
  ROASTER --> TYPES

  ORG     --> DB
  ORG     --> UI
  ORG     --> TYPES

  ADMIN   --> DB
  ADMIN   --> STRIPE_PKG
  ADMIN   --> TYPES

  %% ── Package → external service connections ───────────────────────
  DB          -->|"prisma client\nall CRUD"| NEON
  STRIPE_PKG  -->|"PaymentIntents\ntransfers\nrefunds\ndisputes"| STRIPE_API
  EMAIL_PKG   -->|"send()\nall 11 templates"| RESEND_API
  STRIPE_PKG  -->|"rate limit\nsliding window"| UPSTASH_API

  %% ── Key rules ────────────────────────────────────────────────────
  note1["RULES FOR AI AGENTS:\n1. Never import Stripe directly in an app — use @joe-perks/stripe\n2. Never query DB directly without scoping by entity ID (tenant isolation)\n3. Never call Resend directly — always use sendEmail() for EmailLog dedup\n4. All money values are integers in cents — never floats\n5. Split calculations use calculateSplits() from @joe-perks/stripe only"]:::note

  classDef app  fill:#0F6E56,stroke:#085041,color:#E1F5EE,font-weight:bold
  classDef pkg  fill:#BA7517,stroke:#854F0B,color:#FAEEDA,font-weight:bold
  classDef ext  fill:#534AB7,stroke:#3C3489,color:#EEEDFE
  classDef note fill:#FAEEDA,stroke:#BA7517,color:#412402,text-align:left
